   "source": [
    "def sigmoid(x):\n",
    "    return 1/(1+np.exp(-x))\n",
    "\n",
    "x=np.linspace(-10,10,100)\n",
    "y_sigmoid=sigmoid(x)\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "plt.plot(x,y_sigmoid,label=\"Sigmoid\",color=\"blue\")\n",
    "plt.title(\"Sigmoid activation function\")"
   ]
  },
